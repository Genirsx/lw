{
  "name": "charity-donation-chain-system",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "contracts",
    "web"
  ],
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "scripts": {
    "install:all": "npm install --workspaces",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "demo": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "chain:backfill": "node -e \"console.log('Go server does not include Node backfill script. Use server-node-legacy/scripts/backfillSepolia.js if you still need the legacy flow.')\"",
    "db:up": "docker-compose up -d mysql",
    "db:down": "docker-compose down",
    "db:logs": "docker-compose logs -f mysql",
    "db:init": "node -e \"console.log('Go server reuses SQLite at server/data/app.db. No Node db:init step is required.')\"",
    "dev:server": "cd server && go run ./cmd/api",
    "dev:web": "npm run dev --workspace web",
    "build:web": "npm run build --workspace web",
    "test:contracts": "npm run test --workspace contracts",
    "test:server": "cd server && go test ./..."
  }
}
